# =============================================================================
# mcp-brasil — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores necessários:
#   cp .env.example .env

# --- Transparência (obrigatória para a feature transparencia) ---
# Cadastre-se gratuitamente em:
# https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
TRANSPARENCIA_API_KEY=

# --- DataJud (obrigatória para a feature datajud) ---
# Cadastre-se gratuitamente em:
# https://datajud.cnj.jus.br
DATAJUD_API_KEY=

# --- Anúncios Eleitorais (obrigatória para a feature anuncios_eleitorais) ---
# Obtenha um token em:
# https://developers.facebook.com/docs/marketing-api/reference/ad-library/
META_ACCESS_TOKEN=

# --- Tool Discovery (opcional — valores padrão já funcionam) ---
# Modos: "bm25" (padrão), "code_mode" (experimental), "none" (sem filtro)
# MCP_BRASIL_TOOL_SEARCH=bm25

# --- LLM Discovery — recomendar_tools / planejar_consulta (opcional) ---
# Necessário para as tools recomendar_tools e planejar_consulta (requer: pip install mcp-brasil[llm])
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- HTTP Client (opcional — valores padrão já funcionam) ---
# MCP_BRASIL_HTTP_TIMEOUT=30.0
# MCP_BRASIL_HTTP_MAX_RETRIES=3
# MCP_BRASIL_HTTP_BACKOFF_BASE=1.0
# MCP_BRASIL_USER_AGENT=mcp-brasil/0.7.2
